# Rust / Cargo build output ----------------------------------------
# Top-level workspace target dir and the standalone mkfs workspace's
# target dir. Add additional `**/target/` if you ever spin up more
# nested workspaces.
/target
/mkfs/target
**/*.rs.bk

# Cargo backups / temp files
Cargo.lock.bak
*.swp
*.swo

# Generated kernel / disk images ------------------------------------
# Build artifacts produced by `make` / `cargo run` / linker passes.
# IMPORTANT: do NOT add bare names like `bootblock`, `kernel`, or
# `mkfs` here. Those would also match the crate directories
# `crates/bootblock/`, `kernel/`, `mkfs/` (gitignore patterns without
# slashes match by basename anywhere in the tree) and silently un-
# track entire crates.
#
# Compiled cargo output already lives under `/target/`, which is
# ignored above. Only call out free-standing artifacts here.
*.img
*.elf
*.bin
fs.img
xv6.img

# IDE / editor ------------------------------------------------------
# Track .vscode/settings.json (it pins rust-analyzer's target so the
# whole team gets consistent diagnostics) but ignore everything else
# in .vscode/ that's machine-specific.
/.vscode/*
!/.vscode/settings.json
!/.vscode/extensions.json

/.idea/
*.iml

# rust-analyzer / clippy / rustfmt scratch
.rust-analyzer/

# OS junk -----------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.AppleDouble
.LSOverride

# Logs --------------------------------------------------------------
*.log
